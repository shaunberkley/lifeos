# @plugin(@varlock/infisical-plugin)
# @initInfisical(
#   projectId=$INFISICAL_PROJECT_ID,
#   environment=$INFISICAL_ENVIRONMENT,
#   clientId=$INFISICAL_CLIENT_ID,
#   clientSecret=$INFISICAL_CLIENT_SECRET,
#   siteUrl=https://app.infisical.com,
#   secretPath=/lifeos
# )
# ---

# Active environment for local tooling and agent sessions.
# @type=enum(development, staging, production)
APP_ENV=development

# Infisical machine-identity bootstrap. These values are provided locally and must never be committed with real values.
# @required @type=string
INFISICAL_PROJECT_ID=
# @required @type=string
INFISICAL_ENVIRONMENT=development
# @required @type=infisicalClientId
INFISICAL_CLIENT_ID=
# @required @type=infisicalClientSecret @sensitive
INFISICAL_CLIENT_SECRET=

# Local server defaults that are safe to keep in the schema.
# @type=port @example=3000
PORT=3000
# @required @type=url
WEB_ORIGIN=http://localhost:1337

# Runtime values that should come from Infisical so every human and AI session sees the same platform contract.
# @required @type=url
AUTH_ISSUER=infisical()
# @required @sensitive
BETTER_AUTH_SECRET=infisical()
# @required @type=string
CONVEX_APPLICATION_ID=infisical()
# @required @type=string
CONVEX_DEPLOYMENT=infisical()
# @required @type=url
CONVEX_URL=infisical()
# @required @sensitive
CONVEX_DEPLOY_KEY=infisical()
# @required @type=string
GITHUB_REPOSITORY=infisical()
# @required @sensitive
GITHUB_TOKEN=infisical()
# @required @sensitive
GITHUB_WEBHOOK_SECRET=infisical()
# @required @sensitive
OPENAI_API_KEY=infisical()
# @required @sensitive
LOCAL_BRIDGE_SHARED_SECRET=infisical()

# Local auth state defaults for self-hosted and development mode.
# @type=string
AUTH_DATABASE_PATH=./data/auth.sqlite
# @type=enum(false,true)
BOB_AUTO_RUN=false

# Local-only AI defaults. These may remain local defaults unless you want them centrally managed.
# @required @type=url
OLLAMA_BASE_URL=http://127.0.0.1:11434
# @required @type=string
OLLAMA_MODEL=llama3.1
