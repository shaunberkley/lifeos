{
  "name": "lifeos",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "biome check --write .",
    "prepare": "git config --local core.hooksPath .husky",
    "typecheck": "turbo run typecheck",
    "test": "pnpm exec vitest run convex/*.test.ts && turbo run test",
    "check": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@playwright/test": "1.58.2",
    "@types/node": "25.5.0",
    "convex": "1.34.0",
    "turbo": "2.8.20",
    "typescript": "6.0.2",
    "vitest": "4.1.1"
  }
}
