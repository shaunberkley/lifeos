{
  "name": "lifeos",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "turbo run build",
    "convex:deploy": "varlock run -- pnpm exec convex deploy",
    "convex:dev": "varlock run -- pnpm exec convex dev",
    "dev": "varlock run -- turbo run dev --parallel",
    "dev:bridge": "varlock run -- pnpm --filter @lifeos/local-bridge dev",
    "dev:server": "varlock run -- pnpm --filter @lifeos/server dev",
    "dev:web": "varlock run -- pnpm --filter @lifeos/web dev",
    "lint": "turbo run lint",
    "format": "biome check --write .",
    "prepare": "git config --local core.hooksPath .husky",
    "secrets:check": "varlock load",
    "typecheck": "pnpm typecheck:convex && turbo run typecheck",
    "typecheck:convex": "pnpm exec convex typecheck",
    "test": "pnpm exec vitest run convex/*.test.ts && turbo run test",
    "test:coverage": "pnpm exec vitest run --coverage",
    "check": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@varlock/infisical-plugin": "0.0.5",
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "1.52.0",
    "@types/node": "24.0.0",
    "@vitest/coverage-v8": "4.1.1",
    "convex": "1.34.0",
    "turbo": "2.5.0",
    "typescript": "5.9.2",
    "varlock": "0.6.3",
    "vitest": "4.1.1"
  }
}
