# LifeOS local environment

# Server
PORT=3000

# Authentication and Convex
AUTH_ISSUER=http://localhost:3000
CONVEX_APPLICATION_ID=change-me

# Local bridge
LOCAL_BRIDGE_SHARED_SECRET=change-me-to-a-long-random-string
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Optional future values for self-hosted or integrated modes
# CONVEX_DEPLOYMENT=
# CONVEX_URL=
# AUTH_DATABASE_URL=sqlite:./data/auth.sqlite
