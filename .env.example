# LifeOS local bootstrap environment
#
# This file is for local bootstrap values only.
# Do not store long-lived runtime secrets here once Infisical is configured.
#
# Add these keys in Infisical under:
#   project: lifeos
#   environment: development
#   path: /lifeos
#
#   AUTH_ISSUER=http://localhost:3000
#   BETTER_AUTH_SECRET=
#   CONVEX_APPLICATION_ID=
#   CONVEX_DEPLOYMENT=
#   CONVEX_URL=
#   CONVEX_DEPLOY_KEY=
#   GITHUB_REPOSITORY=shaunberkley/lifeos
#   GITHUB_TOKEN=
#   GITHUB_WEBHOOK_SECRET=
#   OPENAI_API_KEY=
#   LOCAL_BRIDGE_SHARED_SECRET=
#   OLLAMA_BASE_URL=
#   OLLAMA_MODEL=

# Infisical machine identity for Varlock-backed local and agent access
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=development
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=

# Local process defaults
PORT=3000
WEB_ORIGIN=http://localhost:1337

# Optional future values for self-hosted auth or integrated modes
AUTH_DATABASE_PATH=./data/auth.sqlite

# LifeOS Reviewer dogfood defaults
GITHUB_REPOSITORY=shaunberkley/lifeos
LIFEOS_REVIEWER_AUTO_RUN=false
